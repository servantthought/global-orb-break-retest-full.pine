// © ServantThought — MIT License https://opensource.org/licenses/MIT
// Inspired by QuantCrawler's ORB concepts
//@version=6
indicator("Global ORB Break & Retest - Full", overlay=true, max_lines_count=500, max_labels_count=500)

// === INPUTS ===
max_history = input.int(3, "Number of Historical ORBs", minval=1, maxval=30, group="Strategy")
extend_enabled = input.bool(true, "Extend Previous ORBs", group="Strategy")
extend_count   = input.int(1, "Number of ORBs to Extend", minval=1, maxval=10, group="Strategy")
label_offset   = input.int(15, "Label Extension (Bars Right)", minval=0, maxval=150, group="Strategy")

// Alerts
approach_alert   = input.bool(true, "Enable Approach Alerts", group="Alerts")
approach_percent = input.float(0.15, "Approach Alert % Distance (Price %)", minval=0.01, maxval=50.0, step=0.01, group="Alerts", tooltip="Percentage distance from the level to trigger an alert.")

retest_type = input.string("Wick Only", "Retest Confirmation", options=["Wick Only", "Close Confirmation", "Both"], group="Strategy")
use_inverse = input.bool(false, "Inverse Mode", group="Strategy")

// --- INDIVIDUAL PLOTTING TOGGLES ---
// Daily Levels
show_pdh = input.bool(true, "PDH", inline="dly1", group="Daily Levels")
show_pdl = input.bool(true, "PDL", inline="dly1", group="Daily Levels")
show_pdc = input.bool(true, "PDC", inline="dly2", group="Daily Levels")
show_dly_mid = input.bool(true, "Daily Open (Midnight)", inline="dly2", group="Daily Levels")

// Weekly Levels
show_cwh = input.bool(true, "CWH", inline="wk1", group="Weekly Levels")
show_cwl = input.bool(true, "CWL", inline="wk1", group="Weekly Levels")
show_pwh = input.bool(true, "PWH", inline="wk2", group="Weekly Levels")
show_pwl = input.bool(true, "PWL", inline="wk2", group="Weekly Levels")

// Session Opens
show_asia_o = input.bool(true, "Asia Open", inline="so1", group="Session Opens")
show_lon_o  = input.bool(true, "London Open", inline="so1", group="Session Opens")
show_ny_o   = input.bool(true, "NY Open", inline="so1", group="Session Opens")

// Previous Session Highs/Lows
show_p_asia_h = input.bool(true, "Prev Asia High", inline="ps1", group="Prev Session Levels")
show_p_asia_l = input.bool(true, "Prev Asia Low", inline="ps1", group="Prev Session Levels")
show_p_lon_h  = input.bool(true, "Prev London High", inline="ps2", group="Prev Session Levels")
show_p_lon_l  = input.bool(true, "Prev London Low", inline="ps2", group="Prev Session Levels")
show_p_ny_h   = input.bool(true, "Prev NY High", inline="ps3", group="Prev Session Levels")
show_p_ny_l   = input.bool(true, "Prev NY Low", inline="ps3", group="Prev Session Levels")

// ORB Extensions
show_ext_u100 = input.bool(true, "Curr U100%", inline="ext1", group="Current ORB Extensions")
show_ext_u50  = input.bool(true, "Curr U50%", inline="ext1", group="Current ORB Extensions")
show_ext_l50  = input.bool(true, "Curr L50%", inline="ext2", group="Current ORB Extensions")
show_ext_l100 = input.bool(true, "Curr L100%", inline="ext2", group="Current ORB Extensions")

// Manual Magnet Time Toggles (All in NY Time)
plot_man_mid   = input.bool(true, "Plot Midnight", inline="m1", group="Manual Open Times")
time_man_mid   = input.session("0000-0001", "Midnight Time", inline="m1", group="Manual Open Times")

plot_man_1800  = input.bool(true, "Plot 1800 Level", inline="m2", group="Manual Open Times")
time_man_1800  = input.session("1800-1801", "1800 Time", inline="m2", group="Manual Open Times")

plot_man_asia  = input.bool(true, "Plot Asia Open", inline="m3", group="Manual Open Times")
time_man_asia  = input.session("2000-2001", "Asia Open Time", inline="m3", group="Manual Open Times")

plot_man_eur   = input.bool(true, "Plot European Open", inline="m4", group="Manual Open Times")
time_man_eur   = input.session("0200-0201", "European Open Time", inline="m4", group="Manual Open Times")

plot_man_lon   = input.bool(true, "Plot London Open", inline="m5", group="Manual Open Times")
time_man_lon   = input.session("0300-0301", "London Open Time", inline="m5", group="Manual Open Times")

high_color = input.color(color.blue, "ORB High Line Color", group="Colors")
low_color  = input.color(color.red,  "ORB Low Line Color",  group="Colors")

// === SESSIONS ===
en_asia   = input.bool(true, "Enable Asia ORB", group="Asia Session")
asia_sess = input.session("0900-0915", "Asia OR Time", group="Asia Session")
asia_tz   = input.string("Asia/Tokyo", "Asia TZ", group="Asia Session")

en_london   = input.bool(true, "Enable London ORB", group="London Session")
london_sess = input.session("0800-0815", "London OR Time", group="London Session")
london_tz   = input.string("Europe/London", "London TZ", group="London Session")

en_ny   = input.bool(true, "Enable New York ORB", group="New York Session")
ny_sess = input.session("0930-0945", "NY OR Time", group="New York Session")
ny_tz   = input.string("America/New_York", "NY TZ", group="New York Session")

// === TYPE & VARIABLES ===
type OrbData
    string name
    float high_val
    float low_val
    float mid_val
    line hline
    line lline
    line mline
    label hlbl
    label llbl
    label mlbl
    linefill fill_obj
    bool long_bo
    bool short_bo

var array<OrbData> history = array.new<OrbData>()
var OrbData active_orb = na

var line   f_hline = na
var line   f_lline = na
var line   f_mline = na
var float  f_high  = na
var float  f_low   = na
var int    f_start = na
var string f_name  = ""

// STATE TRACKERS
var bool broken_high = false
var bool broken_low  = false

// Last Alert Tracker (Array bypasses scoping limitations)
var string[] last_alert_arr = array.new_string(1, "No alerts yet")

// Global Approach Trackers (Using Arrays to bypass scope limits)
var float[] closest_dist_arr = array.new_float(1, 999999.0)
var string[] closest_name_arr = array.new_string(1, "")
bool is_approaching = false
string approach_msg = ""

// === TRACKERS ===
var float pdh = na, var float pdl = na, var float pdc = na
var float cwh = na, var float cwl = na
var float pwh = na, var float pwl = na
var float cdh = na, var float cdl = na

var float cur_asia_h = na, var float cur_asia_l = na, var float cur_asia_o = na
var float cur_lon_h  = na, var float cur_lon_l  = na, var float cur_lon_o  = na
var float cur_ny_h   = na, var float cur_ny_l   = na, var float cur_ny_o   = na

var float prev_asia_h = na, var float prev_asia_l = na
var float prev_lon_h  = na, var float prev_lon_l  = na
var float prev_ny_h   = na, var float prev_ny_l   = na

var float midnight_level = na

// Manual Trackers
var float man_mid_o = na, var float man_1800_o = na, var float man_asia_o = na
var float man_eur_o = na, var float man_lon_o = na

bool new_day  = ta.change(time("D")) != 0
bool new_week = ta.change(time("W")) != 0

if new_day
    pdh := cdh, pdl := cdl, pdc := close[1]
    midnight_level := open
    cdh := high, cdl := low
else
    if high > nz(cdh, high) or na(cdh)
        cdh := high
    if low < nz(cdl, low) or na(cdl)
        cdl := low

if new_week
    pwh := cwh, pwl := cwl
    cwh := high, cwl := low
else
    if high > nz(cwh, high) or na(cwh)
        cwh := high
    if low < nz(cwl, low) or na(cwl)
        cwl := low

in_asia   = en_asia   and not na(time(timeframe.period, asia_sess, asia_tz))
in_london = en_london and not na(time(timeframe.period, london_sess, london_tz))
in_ny     = en_ny     and not na(time(timeframe.period, ny_sess, ny_tz))

asia_start   = in_asia   and not in_asia[1]
london_start = in_london and not in_london[1]
ny_start     = in_ny     and not in_ny[1]

any_start   = asia_start or london_start or ny_start
is_forming  = in_asia or in_london or in_ny
just_ended  = not is_forming and is_forming[1]

// Track Manual Session Opens (NY Time)
bool in_man_mid = not na(time(timeframe.period, time_man_mid, ny_tz))
if in_man_mid and not in_man_mid[1]
    man_mid_o := open

bool in_man_1800 = not na(time(timeframe.period, time_man_1800, ny_tz))
if in_man_1800 and not in_man_1800[1]
    man_1800_o := open

bool in_man_asia = not na(time(timeframe.period, time_man_asia, ny_tz))
if in_man_asia and not in_man_asia[1]
    man_asia_o := open

bool in_man_eur = not na(time(timeframe.period, time_man_eur, ny_tz))
if in_man_eur and not in_man_eur[1]
    man_eur_o := open

bool in_man_lon = not na(time(timeframe.period, time_man_lon, ny_tz))
if in_man_lon and not in_man_lon[1]
    man_lon_o := open

if asia_start
    prev_asia_h := cur_asia_h, prev_asia_l := cur_asia_l
    cur_asia_h := high, cur_asia_l := low, cur_asia_o := open
else if in_asia
    if high > nz(cur_asia_h, high) or na(cur_asia_h)
        cur_asia_h := high
    if low < nz(cur_asia_l, low) or na(cur_asia_l)
        cur_asia_l := low

if london_start
    prev_lon_h := cur_lon_h, prev_lon_l := cur_lon_l
    cur_lon_h := high, cur_lon_l := low, cur_lon_o := open
else if in_london
    if high > nz(cur_lon_h, high) or na(cur_lon_h)
        cur_lon_h := high
    if low < nz(cur_lon_l, low) or na(cur_lon_l)
        cur_lon_l := low

if ny_start
    prev_ny_h := cur_ny_h, prev_ny_l := cur_ny_l
    cur_ny_h := high, cur_ny_l := low, cur_ny_o := open
else if in_ny
    if high > nz(cur_ny_h, high) or na(cur_ny_h)
        cur_ny_h := high
    if low < nz(cur_ny_l, low) or na(cur_ny_l)
        cur_ny_l := low

// === ORB FORMING & FINALIZE ===
if any_start
    broken_high := false
    broken_low  := false

    if not na(f_high) and not na(f_hline)
        float mid = (f_high + f_low) / 2
        line hl = line.new(f_start, f_high, bar_index, f_high, color=high_color, width=2)
        line ll = line.new(f_start, f_low,  bar_index, f_low,  color=low_color, width=2)
        line ml = line.new(f_start, mid,    bar_index, mid,    color=color.orange, style=line.style_dotted, width=1)
        
        string h_txt = f_name + (use_inverse ? "\nLow" : "\nHigh")
        string l_txt = f_name + (use_inverse ? "\nHigh" : "\nLow")
        
        label hlbl = label.new(bar_index + label_offset, f_high, h_txt, style=label.style_label_left, color=color.new(high_color, 80), textcolor=color.white, size=size.small)
        label llbl = label.new(bar_index + label_offset, f_low,  l_txt, style=label.style_label_left, color=color.new(low_color, 80),  textcolor=color.white, size=size.small)
        label mlbl = label.new(bar_index + label_offset, mid,    f_name + "\nMid",  style=label.style_label_left, color=color.new(color.orange, 80), textcolor=color.white, size=size.small)
        
        line.delete(f_hline), line.delete(f_lline), line.delete(f_mline)
        new_orb = OrbData.new(f_name, f_high, f_low, mid, hl, ll, ml, hlbl, llbl, mlbl, na, false, false)
        array.push(history, new_orb)
        active_orb := new_orb
        
        if array.size(history) > max_history
            OrbData old = array.shift(history)
            line.delete(old.hline), line.delete(old.lline), line.delete(old.mline)
            label.delete(old.hlbl), label.delete(old.llbl), label.delete(old.mlbl)
            if not na(old.fill_obj)
                linefill.delete(old.fill_obj)

    f_high  := high, f_low   := low, f_start := bar_index
    f_name  := asia_start ? "Asia" : london_start ? "London" : "NY"

    f_hline := line.new(f_start, f_high, bar_index, f_high, color=high_color, width=2)
    f_lline := line.new(f_start, f_low,  bar_index, f_low,  color=low_color, width=2)
    f_mline := line.new(f_start, (f_high + f_low)/2, bar_index, (f_high + f_low)/2, color=color.orange, style=line.style_dotted, width=1)

else if is_forming and not na(f_high)
    f_high := math.max(f_high, high), f_low  := math.min(f_low, low)
    
    if barstate.islast
        float mid = (f_high + f_low) / 2
        line.set_xy1(f_hline, f_start, f_high), line.set_xy2(f_hline, bar_index, f_high)
        line.set_xy1(f_lline, f_start, f_low),  line.set_xy2(f_lline, bar_index, f_low)
        line.set_xy1(f_mline, f_start, mid),    line.set_xy2(f_mline, bar_index, mid)

if just_ended and not na(f_high)
    float mid = (f_high + f_low) / 2
    line hl = line.new(f_start, f_high, bar_index, f_high, color=high_color, width=2)
    line ll = line.new(f_start, f_low,  bar_index, f_low,  color=low_color, width=2)
    line ml = line.new(f_start, mid,    bar_index, mid,    color=color.orange, style=line.style_dotted, width=1)
    
    string h_txt = f_name + (use_inverse ? "\nLow" : "\nHigh")
    string l_txt = f_name + (use_inverse ? "\nHigh" : "\nLow")
    label hlbl = label.new(bar_index + label_offset, f_high, h_txt, style=label.style_label_left, color=color.new(high_color, 80), textcolor=color.white, size=size.small)
    label llbl = label.new(bar_index + label_offset, f_low,  l_txt, style=label.style_label_left, color=color.new(low_color, 80),  textcolor=color.white, size=size.small)
    label mlbl = label.new(bar_index + label_offset, mid,    f_name + "\nMid",  style=label.style_label_left, color=color.new(color.orange, 80), textcolor=color.white, size=size.small)
    
    line.delete(f_hline), line.delete(f_lline), line.delete(f_mline)
    new_orb = OrbData.new(f_name, f_high, f_low, mid, hl, ll, ml, hlbl, llbl, mlbl, na, false, false)
    array.push(history, new_orb)
    active_orb := new_orb
    
    if array.size(history) > max_history
        OrbData old = array.shift(history)
        line.delete(old.hline), line.delete(old.lline), line.delete(old.mline)
        label.delete(old.hlbl), label.delete(old.llbl), label.delete(old.mlbl)
        if not na(old.fill_obj)
            linefill.delete(old.fill_obj)
    
    f_high := na, f_low  := na, f_hline := na, f_lline := na, f_mline := na

// === TRADING LOGIC & BO ALERTS ===
bool long_signal = false
bool short_signal = false

if not is_forming and not na(active_orb)
    // Breakout Updates
    if close > active_orb.high_val
        broken_high := true
        active_orb.long_bo := true
    if close < active_orb.low_val
        broken_low := true
        active_orb.short_bo := true

    // Retest Alerts
    if active_orb.long_bo
        bool trigger = false
        if retest_type == "Wick Only"
            trigger := low <= active_orb.mid_val
        else if retest_type == "Close Confirmation"
            trigger := close <= active_orb.mid_val
        else
            trigger := low <= active_orb.mid_val and close <= active_orb.mid_val
            
        if trigger
            string txt = use_inverse ? "🔴 SHORT" : "🔵 LONG"
            long_signal := true
            array.set(last_alert_arr, 0, txt + " " + active_orb.name)

    if active_orb.short_bo
        bool trigger = false
        if retest_type == "Wick Only"
            trigger := high >= active_orb.mid_val
        else if retest_type == "Close Confirmation"
            trigger := close >= active_orb.mid_val
        else
            trigger := high >= active_orb.mid_val and close >= active_orb.mid_val
            
        if trigger
            string txt = use_inverse ? "🔵 LONG" : "🔴 SHORT"
            short_signal := true
            array.set(last_alert_arr, 0, txt + " " + active_orb.name)

alertcondition(long_signal, "Long Entry", "Long Entry")
alertcondition(short_signal, "Short Entry", "Short Entry")

// === RESET APPROACH STATE ===
array.set(closest_dist_arr, 0, 999999.0)
array.set(closest_name_arr, 0, "")
is_approaching := false
approach_msg := ""

// === DYNAMIC APPROACH ALERT HELPER ===
check_approach(float val, string name, bool is_enabled) =>
    if approach_alert and is_enabled and not na(val)
        float dist_pct = math.abs(close - val) / val * 100
        if dist_pct <= approach_percent
            alert("Approaching Level: " + name + " (" + str.tostring(val, format.mintick) + ")", alert.freq_once_per_bar_close)
            array.set(last_alert_arr, 0, "Approaching " + name)
            if dist_pct < array.get(closest_dist_arr, 0)
                array.set(closest_dist_arr, 0, dist_pct)
                array.set(closest_name_arr, 0, name)

// Check Active ORB High/Mid/Low
if not is_forming and not na(active_orb)
    check_approach(active_orb.high_val, active_orb.name + " High", true)
    check_approach(active_orb.mid_val,  active_orb.name + " Mid",  true)
    check_approach(active_orb.low_val,  active_orb.name + " Low",  true)

// === KEY LEVEL PLOTTING & ALERTS ===
var line[]  kl_lines  = array.new_line(26, na)
var label[] kl_labels = array.new_label(26, na)

update_level(int idx, float val, string name, bool is_enabled, float active_open, int target_b) =>
    // Run the approach alert check for this level
    check_approach(val, name, is_enabled)

    if barstate.islast
        line l = array.get(kl_lines, idx)
        label lbl = array.get(kl_labels, idx)
        
        if is_enabled and not na(val)
            color col = val > active_open ? color.red : color.blue
            if na(l)
                array.set(kl_lines, idx, line.new(bar_index, val, target_b, val, color=col, style=line.style_dotted, width=1, extend=extend.left))
                array.set(kl_labels, idx, label.new(target_b, val, name, style=label.style_label_left, color=color.new(color.white, 100), textcolor=col, size=size.small))
            else
                l.set_xy1(bar_index, val)
                l.set_xy2(target_b, val)
                l.set_color(col)
                lbl.set_xy(target_b, val)
                lbl.set_text(name)
                lbl.set_textcolor(col)
        else
            if not na(l)
                l.set_y1(na)
                l.set_y2(na)
                lbl.set_y(na)


// Populate All Levels
float active_open = in_ny ? cur_ny_o : in_london ? cur_lon_o : in_asia ? cur_asia_o : midnight_level
int target_b = bar_index + label_offset

update_level(0, pdh, "PDH", show_pdh, active_open, target_b)
update_level(1, pdl, "PDL", show_pdl, active_open, target_b)
update_level(2, pdc, "PDC", show_pdc, active_open, target_b)
update_level(3, midnight_level, "Daily Open", show_dly_mid, active_open, target_b)

update_level(4, cwh, "CWH", show_cwh, active_open, target_b)
update_level(5, cwl, "CWL", show_cwl, active_open, target_b)
update_level(6, pwh, "PWH", show_pwh, active_open, target_b)
update_level(7, pwl, "PWL", show_pwl, active_open, target_b)

update_level(8, cur_asia_o, "Asia Open", show_asia_o, active_open, target_b)
update_level(9, cur_lon_o, "Lon Open", show_lon_o, active_open, target_b)
update_level(10, cur_ny_o, "NY Open", show_ny_o, active_open, target_b)

update_level(11, prev_asia_h, "Prev Asia H", show_p_asia_h, active_open, target_b)
update_level(12, prev_asia_l, "Prev Asia L", show_p_asia_l, active_open, target_b)
update_level(13, prev_lon_h, "Prev Lon H", show_p_lon_h, active_open, target_b)
update_level(14, prev_lon_l, "Prev Lon L", show_p_lon_l, active_open, target_b)
update_level(15, prev_ny_h, "Prev NY H", show_p_ny_h, active_open, target_b)
update_level(16, prev_ny_l, "Prev NY L", show_p_ny_l, active_open, target_b)

float ext_u100 = na, float ext_u50 = na, float ext_l50 = na, float ext_l100 = na
if not na(active_orb)
    float orb_rng = active_orb.high_val - active_orb.low_val
    ext_u100 := active_orb.high_val + orb_rng
    ext_u50  := active_orb.high_val + orb_rng * 0.5
    ext_l50  := active_orb.low_val - orb_rng * 0.5
    ext_l100 := active_orb.low_val - orb_rng
    
update_level(17, ext_u100, "Curr U100%", show_ext_u100 and not na(active_orb), active_open, target_b)
update_level(18, ext_u50,  "Curr U50%",  show_ext_u50 and not na(active_orb), active_open, target_b)
update_level(19, ext_l50,  "Curr L50%",  show_ext_l50 and not na(active_orb), active_open, target_b)
update_level(20, ext_l100, "Curr L100%", show_ext_l100 and not na(active_orb), active_open, target_b)

update_level(21, man_mid_o,  "Midnight",   plot_man_mid,  active_open, target_b)
update_level(22, man_1800_o, "1800",       plot_man_1800, active_open, target_b)
update_level(23, man_asia_o, "Asia Open",  plot_man_asia, active_open, target_b)
update_level(24, man_eur_o,  "Europe Open",plot_man_eur,  active_open, target_b)
update_level(25, man_lon_o,  "London Open",plot_man_lon,  active_open, target_b)

// Update final approaching flag for the table
string final_closest = array.get(closest_name_arr, 0)
if final_closest != ""
    is_approaching := true
    approach_msg := "Near " + final_closest

// === FIXED EXTEND LOGIC ===
if barstate.islast and array.size(history) > 0 and extend_enabled
    int hist_size = array.size(history)
    int start_idx = math.max(0, hist_size - extend_count)
    for i = 0 to hist_size - 1
        OrbData o = array.get(history, i)
        if (i >= start_idx)
            o.hline.set_x2(bar_index), o.lline.set_x2(bar_index), o.mline.set_x2(bar_index)
            o.hlbl.set_x(bar_index + label_offset), o.llbl.set_x(bar_index + label_offset), o.mlbl.set_x(bar_index + label_offset)
            if na(o.fill_obj)
                o.fill_obj := linefill.new(o.hline, o.lline, color=color.new(color.gray, 90))
            o.mlbl.set_text(o.name), o.mlbl.set_style(label.style_none), o.mlbl.set_textcolor(color.orange)
        else
            if not na(o.fill_obj)
                linefill.delete(o.fill_obj), o.fill_obj := na
                o.mlbl.set_text(o.name + "\nMid"), o.mlbl.set_style(label.style_label_left), o.mlbl.set_color(color.new(color.orange, 80)), o.mlbl.set_textcolor(color.white)

// === 2-ROW STATUS TABLE ===
var table st = table.new(position.bottom_right, 1, 2, bgcolor=color.new(color.black, 80))

if barstate.islast
    string row0 = ""
    color col0 = color.gray
    
    if is_forming
        row0 := "⏳ Forming " + f_name
        col0 := color.gray
    else if not na(active_orb)
        string bias_str = active_orb.long_bo ? (use_inverse ? "Short Bias" : "Long Bias") : active_orb.short_bo ? (use_inverse ? "Long Bias" : "Short Bias") : "No Bias"
        color bias_col = (active_orb.long_bo and not use_inverse) or (active_orb.short_bo and use_inverse) ? color.blue : color.red
        
        if is_approaching
            row0 := "⚠️ " + approach_msg + " (" + bias_str + ")"
            col0 := color.orange
        else
            row0 := (bias_col == color.blue ? "🔵 " : "🔴 ") + bias_str + " (" + active_orb.name + ")"
            col0 := bias_col
    else
        row0 := "👀 Waiting for Session"
        col0 := color.gray

    string last_alert_str = array.get(last_alert_arr, 0)
    
    table.cell(st, 0, 0, row0, text_color=color.white, bgcolor=color.new(col0, 70), text_size=size.small)
    table.cell(st, 0, 1, "Last Alert: " + (last_alert_str != "" ? last_alert_str : "None"), text_color=color.silver, bgcolor=color.new(color.black, 70), text_size=size.small)